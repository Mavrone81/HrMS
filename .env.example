# ============================================================
# EzyHRM Environment Variables
# Copy to .env and fill in all values before running
# ============================================================

# ---- Encryption (AES-256-GCM) ----
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_key_here

# ---- JWT (RS256 keypairs auto-generated on first run) ----
# Or set explicitly for production:
JWT_PRIVATE_KEY_PATH=./certs/private.pem
JWT_PUBLIC_KEY_PATH=./certs/public.pem
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ---- PostgreSQL ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=hrms
POSTGRES_PASSWORD=hrms_secret_2025
POSTGRES_ROOT_DB=postgres

# Per-service DB names (auto-created on first run)
AUTH_DB=hrms_auth
EMPLOYEE_DB=hrms_employee
PAYROLL_DB=hrms_payroll
LEAVE_DB=hrms_leave
CLAIMS_DB=hrms_claims
RECRUITMENT_DB=hrms_recruitment
ATTENDANCE_DB=hrms_attendance
OFFBOARDING_DB=hrms_offboarding
NOTIFICATION_DB=hrms_notification
REPORTING_DB=hrms_reporting

# ---- SMTP (Nodemailer) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@ezyhRM.sg

# ---- Service Ports ----
API_GATEWAY_PORT=4000
AUTH_SERVICE_PORT=4001
EMPLOYEE_SERVICE_PORT=4002
PAYROLL_SERVICE_PORT=4003
LEAVE_SERVICE_PORT=4004
CLAIMS_SERVICE_PORT=4005
RECRUITMENT_SERVICE_PORT=4006
ATTENDANCE_SERVICE_PORT=4007
OFFBOARDING_SERVICE_PORT=4008
NOTIFICATION_SERVICE_PORT=4009
REPORTING_SERVICE_PORT=4010

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:4000/api
FRONTEND_PORT=3000

# ---- App ----
NODE_ENV=development
LOG_LEVEL=info
COMPANY_UEN=202512345A
COMPANY_NAME=EzyHRM Pte Ltd
