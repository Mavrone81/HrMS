// Prisma schema for notification-service

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  type        NotifType        @default(IN_APP)
  title       String
  body        String
  isRead      Boolean          @default(false)
  readAt      DateTime?
  meta        Json?
  createdAt   DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

enum NotifType { IN_APP EMAIL SMS }
