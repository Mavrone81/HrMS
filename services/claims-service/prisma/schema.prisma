// Prisma schema for claims-service

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ClaimCategory {
  id              String   @id @default(uuid())
  code            String   @unique
  name            String
  maxAmount       Float?
  requiresReceipt Boolean  @default(true)
  isGstClaimable  Boolean  @default(false)
  requiresApproval Boolean @default(true)
  isActive        Boolean  @default(true)

  claims Claim[]

  @@map("claim_categories")
}

model Claim {
  id              String       @id @default(uuid())
  employeeId      String
  categoryId      String
  title           String
  description     String?
  claimDate       DateTime
  totalAmount     Float
  gstAmount       Float        @default(0)
  currency        String       @default("SGD")
  status          ClaimStatus  @default(DRAFT)
  submittedAt     DateTime?
  approvedById    String?      // Finance Admin
  approvedAt      DateTime?
  rejectedReason  String?
  payrollPeriod   String?      // period this will be reimbursed in
  receiptPaths    String[]
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  category ClaimCategory @relation(fields: [categoryId], references: [id])
  items    ClaimItem[]

  @@index([employeeId])
  @@index([status])
  @@map("claims")
}

model ClaimItem {
  id          String   @id @default(uuid())
  claimId     String
  description String
  amount      Float
  gstAmount   Float    @default(0)
  receiptRef  String?

  claim Claim @relation(fields: [claimId], references: [id])

  @@map("claim_items")
}

enum ClaimStatus { DRAFT SUBMITTED APPROVED REJECTED PAID CANCELLED }
